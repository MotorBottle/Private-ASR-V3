# Backend Configuration
PORT=3000
NODE_ENV=production
DATA_DIR=/app/runtime
UPLOAD_MAX_MB=512
POLL_INTERVAL_MS=5000

# Security
JWT_SECRET=replace-with-a-long-random-secret
INVITATION_CODE=replace-with-your-invitation-code

# CORS Configuration
FRONTEND_URL=http://localhost:8080,http://127.0.0.1:8080

# Web Frontend Runtime Configuration
# Set the full browser-facing app backend base URL.
# Recommended for production/front-back separated deployment, e.g.
# API_BASE_URL=https://asrapi.example.com/api/v1
# If left empty, the frontend falls back to the current host on port 3000,
# for example http://localhost:3000/api/v1 or https://your-host:3000/api/v1.
API_BASE_URL=

# ASR API Configuration
ASR_API_URL=http://host.docker.internal:17869
ASR_LANGUAGE=zh
ASR_TIMEOUT=1800000

# LLM Summary Configuration
LLM_API_BASE=http://host.docker.internal:18434/v1
LLM_API_KEY=replace-with-your-llm-api-key
LLM_MODEL=qwen3.5-122b
LLM_TIMEOUT=1200000
LLM_BATCH_MAX_LENGTH=12000
LLM_BATCH_DELAY_MS=1000
